  "sequence": {
    "order": "fixed",
    "components": [
      "ConsentPage",
      "IntroPage",
      "PreTrialEstimation",
      {
        "order": "random",
        "components": [
          "trial1B", "trial2B", "trial3B", "trial4B",
          "myAttentionCheckComponent",
          "trial5B", "trial6B", "trial7B", "trial8B", "trial9B", "trial10B", "trial11B",
          "myAttentionCheckComponent",
          "trial12B", "trial13B", "trial14B", "trial15B", "trial16B", "trial17B", "trial18B", "trial19B", "trial20B", "trial21B", "trial22B", "trial23B", "trial24B",
          "trial25B", "trial26B", "trial27B", "trial28B", "trial29B", "trial30B", "trial31B", "trial32B", "trial33B", "trial34B", "trial35B", "trial36B"
        ],
        "skip": [
          {
            "name": "myAttentionCheckComponent",
            "check": "repeatedComponent",
            "condition": "numIncorrect",
            "value": 2,
            "to": "end"
          }
        ]
      },
      "BlindSpotQuestionnaire",
      "PostQuestionnaire",
      "EndPage"
    ]
  }
