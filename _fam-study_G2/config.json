{
  "$schema": "https://raw.githubusercontent.com/revisit-studies/study/v2.4.2/src/parser/StudyConfigSchema.json",
  "studyMetadata": {
    "title": "Familiarity study - Part 2 GroupA",
    "version": "1",
    "authors": [
      "Amandine"
    ],
    "date": "2025-12-02",
    "description": "First Part",
    "organizations": [
      "inria"
    ]
  },
  "uiConfig": {
    "contactEmail": "",
    "helpTextPath": "assets/content/help.md",
    "logoPath": "revisitAssets/revisitLogoSquare.svg",
    "withProgressBar": true,
    "autoDownloadStudy": false,
    "withSidebar": true,
    "nextOnEnter": true,
    "enumerateQuestions": true,
    "studyEndMsg": "Thank you for completing the study. You may click this link and return to Prolific: [X](X)",
    "urlParticipantIdParam": "PROLIFIC_PID"
  },
  "baseComponents": {
    "icon-task": {
      "type": "website",
      "path": "trial_test.html",
      "instruction": "Look at the image and answer the questions.",
      "forceCompletion": true,
      "nextButtonLocation": "belowStimulus",
      "parameters": {
        "imageFile": "file",
        "objectName": "value"
      },
      "response": [
        {
          "id": "completionSignal",
          "type": "reactive",
          "prompt": "Click on next to continue with another object",
          "required": true,
          "hidden": true
        },
        {
          "id": "objectName",
          "type": "reactive",
          "required": false,
          "hidden": true,
          "prompt": "Object Name"
        },
        {
          "id": "retrievalAnswer",
          "type": "reactive",
          "required": false,
          "hidden": true,
          "prompt": "Choose an answer"
        },
        {
          "id": "confidence",
          "type": "reactive",
          "required": false,
          "hidden": true,
          "prompt": "Confidence"
        }
      ]
    }
  },
  "components": {
    "myAttentionCheckComponent": {
      "type": "questionnaire",
      "response": [
        {
          "id": "AttentionCheck1",
          "prompt": "The colour test you are about to take part in is very simple, when asked for your favorite colour you must select 'Orange'. This is an attention check.\n\nBased on the text you read above what colour have you been asked to enter ?",
          "required": true,
          "type": "radio",
          "options": [
            "Blue",
            "Yellow",
            "Orange",
            "Red",
            "Green"
          ]
        }
      ],
      "correctAnswer": [
        {
          "id": "AttentionCheck1",
          "answer": "Orange"
        }
      ]
    },
    "ConsentPage": {
      "type": "markdown",
      "path": "assets/content/consent.md",
      "nextButtonText": "I agree",
      "response": []
    },
    "IntroPage": {
      "type": "markdown",
      "path": "assets/content/instructions.md",
      "response": [
        {
          "id": "prolificId",
          "prompt": "Your Prolific ID (automatically filled in)",
          "required": true,
          "location": "belowStimulus",
          "type": "shortText",
          "placeholder": "Prolific ID",
          "paramCapture": "PROLIFIC_PID"
        }
      ]
    },
    "PreTrialEstimation": {
      "type": "questionnaire",
      "response": [
        {
          "id": "estimationRecognition",
          "prompt": "In your opinion, how many of the 24 objects you saw in Part 1 do you think you could identify if given their name?",
          "required": true,
          "location": "belowStimulus",
          "type": "numerical",
          "min": 0,
          "max": 24,
          "placeholder": "Select a number between 0 and 24"
        },
        {
          "id": "estimationSource",
          "prompt": "Among the objects you think you will remember, can you estimate the ratio for which you could correctly identify the source — real or virtual — of the object?",
          "required": true,
          "location": "belowStimulus",
          "type": "slider",
          "startingValue": 0,
          "options": [
            { "label": "0%", "value": 0 },
            { "label": "25%", "value": 25 },
            { "label": "50%", "value": 50 },
            { "label": "75%", "value": 75 },
            { "label": "100%", "value": 100 }
          ]
        }
      ]
    },
