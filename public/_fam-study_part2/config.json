      ]
    },
  "EndPage": {
    "type": "markdown",
    "path": "assets/content/end.md",
    "response": []
  }

},
  "sequence": {
    "order": "fixed",
    "components": [
      "ConsentPage",
      "IntroPage",
      "PreTrialEstimation",
      {
        "order": "random",
        "components": [
          "trial1", "trial2", "trial3", "trial4",
          "myAttentionCheckComponent",
          "trial5", "trial6", "trial7", "trial8", "trial9", "trial10", "trial11",
          "myAttentionCheckComponent",
          "trial12", "trial13", "trial14", "trial15", "trial16", "trial17", "trial18", "trial19", "trial20", "trial21", "trial22", "trial23", "trial24",
          "trial25", "trial26", "trial27"
        ],
        "skip": [
          {
            "name": "myAttentionCheckComponent",
            "check": "repeatedComponent",
            "condition": "numIncorrect",
            "value": 2,
            "to": "end"
          }
        ]
      },
      "BlindSpotQuestionnaire",
      "PostQuestionnaire",
      "EndPage"
    ]
  }
}
