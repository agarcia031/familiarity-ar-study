          "required": false,
          "hidden": true,
          "prompt": "Additional explanation"
        },
        {
          "id": "completionSignal",
          "type": "reactive",
          "location": "sidebar",
          "prompt": "Click on next to continue",
          "required": true,
          "hidden": true
        }
      ]
    },
    
    "PostQuestionnaire": {
      "type": "questionnaire",
      "response": [
        {
          "id": "q1",
          "prompt": "Did you experience any problems with our study? For example, did anything not render or display properly? Any other issues or anything you would like to tell us?",
          "location": "belowStimulus",
