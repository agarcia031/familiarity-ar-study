    "title": "Familiarity study - Part 1",
    "version": "1",
    "authors": [
      "Leana"
    ],
    "date": "2025-12-02",
    "description": "First Part",
    "organizations": [
      "inria"
    ]
  },
  "uiConfig": {
    "contactEmail": "amandine",
    "helpTextPath": "_fam-study/assets/content/help.md",
    "logoPath": "revisitAssets/revisitLogoSquare.svg",
    "withProgressBar": true,
    "autoDownloadStudy": false,
    "withSidebar": true,
    "nextOnEnter": true,
    "enumerateQuestions": false,
    "studyEndMsg": "Thank you for completing the study. You may click this link and return to Prolific: [X](X)",
    "urlParticipantIdParam": "PROLIFIC_PID"
  },
  "baseComponents": {
    "video-task-template": {
      "type": "website",
      "path": "_fam-study/trial.html",
      "instruction": "Watch the video and answer the questions.",
      "forceCompletion": true,
      "nextButtonLocation": "belowStimulus",
      "response": [
        {
          "id": "completionSignal",
          "type": "reactive",
          "location": "sidebar",
          "prompt": "Click on next to continue with another object",
          "required": true,
          "hidden": true
        },
        {
          "id": "objectName",
          "type": "reactive",
          "required": false,
          "hidden": true,
          "prompt": "Object Name"
        }
        ,
        {
          "id": "sourceChoice",
          "type": "reactive",
          "required": false,
          "hidden": true,
          "prompt": "Was this object real or virtual?"
        }
      ]
    },
    "overclaiming-question-template": {
      "type": "questionnaire",
      "nextButtonLocation": "aboveStimulus",
      "response": []
    }
  },
  "components": {
    "myAttentionCheckComponent": {
      "type": "questionnaire",
      "nextButtonLocation": "belowStimulus",
      "response": [
        {
          "id": "AttentionCheck1",
          "prompt": "The colour test you are about to take part in is very simple, when asked for your favorite colour you must select 'Green'. This is an attention check.\n\nBased on the text you read above what colour have you been asked to enter ?",
          "required": true,
          "type": "radio",
          "options": [
            "Blue",
            "Yellow",
            "Orange",
            "Red",
            "Green"
          ]
        }
      ],
      "correctAnswer": [
        {
          "id": "AttentionCheck1",
          "answer": "Green"
        }
      ]
    },
    "SelfAssessment": {
      "type": "questionnaire",
      "instruction": "Please answer the following two questions of self-assessment.",
      "response": [
        {
          "id": "SelfAssessedQ1",
          "prompt": "How familiar are you with new technologies?",
          "type": "likert",
          "required": true,
          "numItems": 7,
          "rightLabel": "Extremely",
          "leftLabel": "Not at all",
          "location": "belowStimulus"
        },
        {
          "id": "SelfAssessedQ2",
          "prompt": "How would you define your level of expertise in new technologies?",
          "type": "likert",
          "required": true,
          "numItems": 7,
          "rightLabel": "Extremely",
          "leftLabel": "Not at all",
          "location": "belowStimulus"
        }
      ]
    },
    "IntroGlobal": {
      "type": "markdown",
      "path": "_fam-study/assets/content/part1_instructions_global.md",
      "nextButtonText": "Start",
      "response": [
        {
          "id": "prolificId",
          "prompt": "Your Prolific ID (automatically filled in)",
          "required": true,
          "location": "belowStimulus",
          "type": "shortText",
          "placeholder": "Prolific ID",
          "paramCapture": "PROLIFIC_PID"
        }
      ]
    },
    "IntroPageOCT": {
