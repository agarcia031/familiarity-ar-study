{
  "$schema": "https://raw.githubusercontent.com/revisit-studies/study/v2.4.2/src/parser/StudyConfigSchema.json",
  "studyMetadata": {
    "title": "Familiarity study - Part 2",
    "version": "1",
    "authors": [
      "Leana, Amandine"
    ],
    "date": "2025-12-02",
    "description": "Second Part",
    "organizations": [
      "inria"
    ]
  },
  "uiConfig": {
    "contactEmail": "",
    "helpTextPath": "_fam-study_part2/assets/content/help.md",
    "logoPath": "revisitAssets/revisitLogoSquare.svg",
    "withProgressBar": true,
    "autoDownloadStudy": false,
    "withSidebar": true,
    "nextOnEnter": true,
    "enumerateQuestions": true,
    "studyEndMsg": "Thank you for completing the study. You may click this link and return to Prolific: [https://app.prolific.com/submissions/complete?cc=C12F1D39](https://app.prolific.com/submissions/complete?cc=C12F1D39)",
    "urlParticipantIdParam": "PROLIFIC_PID"
  },
  "baseComponents": {
    "icon-task": {
      "type": "website",
      "path": "_fam-study_part2/trial_test.html",
      "instruction": "Look at the image and answer the questions.",
      "forceCompletion": true,
      "nextButtonLocation": "belowStimulus",
      "parameters": {
        "imageFile": "file",
        "objectName": "value"
      },
      "response": [
        {
          "id": "completionSignal",
          "type": "reactive",
          "prompt": "Click on next to continue with another object",
          "required": true,
          "hidden": true
        },
        {
          "id": "objectName",
          "type": "reactive",
          "required": false,
          "hidden": true,
          "prompt": "Object Name"
        },
        {
          "id": "retrievalAnswer",
          "type": "reactive",
          "required": false,
          "hidden": true,
          "prompt": "Choose an answer"
        },
        {
          "id": "confidence",
          "type": "reactive",
          "required": false,
          "hidden": true,
          "prompt": "Confidence"
        }
      ]
    }
  },
  "components": {
    "attentionCheck1": {
      "type": "questionnaire",
      "nextButtonLocation": "belowStimulus",
      "instruction": "Attention check",
      "instructionLocation": "sidebar",
      "response": [
        {
          "id": "attention1",
          "prompt": "To show you're reading the instructions carefully, please ignore the question below and select *Orange*, whatever your real answer would be.\n\nWhat is your favourite colour?",
          "required": true,
          "type": "radio",
          "options": ["Blue", "Yellow", "Orange", "Red", "Green"]
        }
      ],
      "correctAnswer": [{ "id": "attention1", "answer": "Orange" }]
    },
    "attentionCheck2": {
      "type": "questionnaire",
      "nextButtonLocation": "belowStimulus",
      "instruction": "Attention check",
      "instructionLocation": "sidebar",
      "response": [
        {
          "id": "attention2",
          "prompt": "Please ignore the question below and select *Yellow*, whatever your real answer would be.\n\nWhat is your favourite colour?",
          "required": true,
          "type": "radio",
          "options": ["Blue", "Yellow", "Orange", "Red", "Green"]
        }
      ],
      "correctAnswer": [{ "id": "attention2", "answer": "Yellow" }]
    },
    "ConsentPage": {
      "type": "markdown",
      "instruction": "Welcome back!",
      "instructionLocation": "sidebar",
      "path": "_fam-study_part2/assets/content/part2_consent.md",
      "nextButtonText": "I agree",
      "response": []
    },
    "IntroPage": {
      "type": "markdown",
      "path": "_fam-study_part2/assets/content/part2_instructions.md",
      "instruction": "Please read the following instructions before starting the study.",
      "instructionLocation": "sidebar",
      "response": [
        {
          "id": "prolificId",
          "prompt": "Your Prolific ID (automatically filled in)",
          "required": true,
          "location": "belowStimulus",
          "type": "shortText",
          "placeholder": "Prolific ID",
          "paramCapture": "PROLIFIC_PID"
        }
      ]
    },
    "MetaAssessment": {
      "type": "questionnaire",
      "instruction": "These two questions ask for your best guess. A rough ballpark is exactly what we're looking for — it's completely normal not to know for sure, so just go with your overall impression.",
      "instructionLocation": "sidebar",
      "response": [
        {
          "id": "estimationRecognition",
          "prompt": "Out of the **18** objects you saw in Part 1, roughly how many do you think you recognised today?",
          "required": true,
          "location": "belowStimulus",
          "type": "slider",
          "snap": false,
          "step": 1,
          "startingValue": 9,
          "options": [
            { "label": "0", "value": 0 },
            { "label": "9", "value": 9 },
            { "label": "18", "value": 18 }
          ]
        },
        {
          "id": "estimationSource",
          "prompt": "Among the objects you recognised, roughly what proportion do you think you correctly identified as real or virtual?",
          "required": true,
          "location": "belowStimulus",
          "type": "slider",
          "startingValue": 50,
          "options": [
            { "label": "0%", "value": 0 },
            { "label": "25%", "value": 25 },
            { "label": "50%", "value": 50 },
            { "label": "75%", "value": 75 },
            { "label": "100%", "value": 100 }
          ]
        }
      ]
    },
    "trial1": {
      "baseComponent": "icon-task",
      "parameters": {
        "imageFile": "assets/icons/screwdriver.png",
        "objectName": "Screwdriver",
