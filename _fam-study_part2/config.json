{
  "$schema": "https://raw.githubusercontent.com/revisit-studies/study/v2.4.2/src/parser/StudyConfigSchema.json",
  "studyMetadata": {
    "title": "Familiarity study - Part 2",
    "version": "1",
    "authors": [
      "Leana, Amandine"
    ],
    "date": "2025-12-02",
    "description": "Second Part",
    "organizations": [
      "inria"
    ]
  },
  "uiConfig": {
    "contactEmail": "",
    "helpTextPath": "_fam-study_part2/assets/content/help.md",
    "logoPath": "revisitAssets/revisitLogoSquare.svg",
    "withProgressBar": true,
    "autoDownloadStudy": false,
    "withSidebar": true,
    "nextOnEnter": true,
    "enumerateQuestions": true,
    "studyEndMsg": "Thank you for completing the study. You may click this link and return to Prolific: [https://app.prolific.com/submissions/complete?cc=C12F1D39](https://app.prolific.com/submissions/complete?cc=C12F1D39)",
    "urlParticipantIdParam": "PROLIFIC_PID"
  },
  "baseComponents": {
    "icon-task": {
      "type": "website",
      "path": "_fam-study_part2/trial_test.html",
      "instruction": "Look at the image and answer the questions.",
      "forceCompletion": true,
      "nextButtonLocation": "belowStimulus",
      "parameters": {
        "imageFile": "file",
        "objectName": "value"
      },
      "response": [
        {
          "id": "completionSignal",
          "type": "reactive",
          "prompt": "Click on next to continue with another object",
          "required": true,
          "hidden": true
        },
        {
          "id": "objectName",
          "type": "reactive",
          "required": false,
          "hidden": true,
          "prompt": "Object Name"
        },
        {
          "id": "retrievalAnswer",
          "type": "reactive",
          "required": false,
          "hidden": true,
          "prompt": "Choose an answer"
        },
        {
          "id": "confidence",
          "type": "reactive",
          "required": false,
          "hidden": true,
          "prompt": "Confidence"
        }
      ]
    }
  },
  "components": {
    "myAttentionCheckComponent": {
      "type": "questionnaire",
      "response": [
        {
          "id": "AttentionCheck1",
          "prompt": "The colour test you are about to take part in is very simple, when asked for your favorite colour you must select 'Orange'. This is an attention check.\n\nBased on the text you read above what colour have you been asked to enter ?",
          "required": true,
          "type": "radio",
          "options": [
            "Blue",
            "Yellow",
            "Orange",
            "Red",
            "Green"
          ]
        }
      ],
      "correctAnswer": [
        {
          "id": "AttentionCheck1",
          "answer": "Orange"
        }
      ]
    },
    "ConsentPage": {
      "type": "markdown",
      "path": "_fam-study_part2/assets/content/part2_consent.md",
      "nextButtonText": "I agree",
      "response": []
    },
    "IntroPage": {
      "type": "markdown",
      "path": "_fam-study_part2/assets/content/part2_instructions.md",
      "instruction": "Please read the following instructions before starting the study.",
      "instructionLocation": "sidebar",
      "response": [
        {
          "id": "prolificId",
          "prompt": "Your Prolific ID (automatically filled in)",
          "required": true,
          "location": "belowStimulus",
          "type": "shortText",
          "placeholder": "Prolific ID",
          "paramCapture": "PROLIFIC_PID"
        }
      ]
    },
    "PreTrialEstimation": {
      "type": "questionnaire",
      "instruction": "These two questions ask for your best guess. A rough ballpark is exactly what we're looking for — it's completely normal not to know for sure, so just go with your overall impression.",
      "instructionLocation": "sidebar",
      "response": [
        {
          "id": "estimationRecognition",
          "prompt": "Out of the **18** objects you saw in Part 1, roughly how many do you think you could still recognise today?",
          "required": true,
          "location": "belowStimulus",
          "type": "slider",
          "snap": false,
          "step": 1,
          "startingValue": 9,
          "options": [
            { "label": "0", "value": 0 },
            { "label": "9", "value": 9 },
            { "label": "18", "value": 18 }
          ]
        },
        {
          "id": "estimationSource",
          "prompt": "Among the objects you think you'll remember, roughly what proportion could you correctly identify as real or virtual?",
          "required": true,
          "location": "belowStimulus",
          "type": "slider",
          "startingValue": 50,
          "options": [
            { "label": "0%", "value": 0 },
            { "label": "25%", "value": 25 },
            { "label": "50%", "value": 50 },
            { "label": "75%", "value": 75 },
            { "label": "100%", "value": 100 }
          ]
        }
      ]
    },
